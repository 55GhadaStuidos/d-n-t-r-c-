name: Borte Build
on: [push] # Sen kodu her güncellediğinde çalışır
jobs:
  build:
    runs-on: ${{ matrix.os }}
    strategy:
      matrix:
        os: [windows-latest, macos-latest]
    steps:
      - uses: actions/checkout@v3
      - uses: actions/setup-node@v3
        with:
          node-version: 18
      - run: npm install
      - run: npm run make # Electron-forge kullanıyorsan paketleri hazırlar
      - name: Upload Build
        uses: actions/upload-artifact@v3
        with:
          name: Borte-${{ matrix.os }}
          path: out/make/ # Çıkan .exe ve .dmg burada olacak
